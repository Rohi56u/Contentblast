PORT=3000
NODE_ENV=production

# REDIS (Free: https://upstash.com or local: redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# TELEGRAM (100% Free) — Message @BotFather → /newbot → Copy token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# REDDIT (100% Free) — reddit.com/prefs/apps → Create script app
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=ContentBlast/1.0

# DISCORD (100% Free) — discord.com/developers → New App → Bot → Token
DISCORD_BOT_TOKEN=your_discord_bot_token

# FACEBOOK — Playwright automation (use secondary account)
FACEBOOK_EMAIL=your_facebook_email
FACEBOOK_PASSWORD=your_facebook_password

# WHATSAPP — First run: scan QR code in terminal
WHATSAPP_SESSION_PATH=./sessions/whatsapp

# LINKEDIN — Playwright automation
LINKEDIN_EMAIL=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password

# TWITTER/X — Playwright automation (Twitter API is paid now)
TWITTER_USERNAME=your_twitter_username
TWITTER_PASSWORD=your_twitter_password
TWITTER_PHONE=your_phone_optional

# AI CAPTIONS (Optional)
# FREE: Install Ollama → ollama pull mistral → set OLLAMA_ENABLED=true
# PAID: OpenAI API key
OLLAMA_ENABLED=false
OLLAMA_MODEL=mistral
OPENAI_API_KEY=

# PROXIES (Optional — for anti-ban)
# Format: http://ip:port,http://ip:port
PROXY_LIST=
USE_FREE_PROXIES=false

# ANTI-SPAM
MIN_DELAY_BETWEEN_POSTS_MS=30000
MAX_DELAY_BETWEEN_POSTS_MS=90000
MAX_POSTS_PER_GROUP_PER_DAY=1
MAX_POSTS_PER_PLATFORM_PER_HOUR=5

# SCHEDULING
ENABLE_BEST_TIME_SCHEDULING=true
DEFAULT_TIMEZONE=Asia/Kolkata
